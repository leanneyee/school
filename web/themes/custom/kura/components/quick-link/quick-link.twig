<a href="{{ url }}" class="group flex items-center justify-between gap-3 px-5 py-5 text-white transition hover:bg-white/10">
  <span class="flex items-center gap-3">
    {% if icon %}
      <span class="text-brand-sun">
        {{- include('@kura/components/icon/icon.twig', { weight: 'bold', icon: icon, icon_size: 'extra-small' }, with_context: false) -}}
      </span>
    {% endif %}
    <span class="text-sm font-semibold uppercase tracking-wider">{{ label }}</span>
  </span>
  <span class="opacity-0 transition group-hover:opacity-100" aria-hidden="true">
    {{- include('@kura/components/icon/icon.twig', { weight: 'bold', icon: 'arrow-up-right', icon_size: 'extra-small' }, with_context: false) -}}
  </span>
</a>
