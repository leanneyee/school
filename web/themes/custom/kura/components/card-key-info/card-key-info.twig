<div class="px-6 py-10 sm:px-10">
  <dl>
    {% if heading %}
      <dt class="text-xs font-semibold uppercase tracking-[0.25em] text-muted-foreground">{{ heading }}</dt>
    {% endif %}
    {% if value %}
      <dd class="mt-3 text-3xl font-bold text-foreground">{{ value }}</dd>
    {% endif %}
    {% if subtext %}
      <dd class="mt-2 text-sm text-muted-foreground">{{ subtext }}</dd>
    {% endif %}
  </dl>
</div>
