{% set card_orientation = orientation|default('vertical') %}
{% set card_style = style|default('framed') %}
{% set card_background = background|default('noColor') %}
{% set is_text_centered = is_text_centered|default(false) ? 'yes' : 'no' %}
{% set is_media_bg = card_style == 'media_bg' %}
{% set h = 'h' ~ level|default(3) %}
{# Style-varying class strings — keeps the content section unified rather than duplicated. #}
{% set heading_classes = is_media_bg
  ? (eyebrow_text is not empty ? 'mt-1 ' : '') ~ 'text-2xl font-bold'
  : 'text-xl font-semibold @sm:text-2xl @2xl:text-3xl' %}
{% set text_classes = is_media_bg
  ? 'mb-0 mt-2 text-sm text-white'
  : 'mb-0 text-md @sm:text-lg @2xl:text-xl' %}
{% set inner_classes = is_media_bg ? '' : '@container flex w-full flex-col gap-1 md:gap-2' %}

{% set card =
  html_cva(
    base: [
      'group relative flex rounded-xl shadow-2xl transition duration-300 in-[.views-row]:h-full',
      'focus-within:ring-2 focus-within:ring-ring/50'
    ],
    variants: {
      orientation: {
        vertical: 'flex-col',
        horizontal: 'md:flex-row'
      },
      clickable: {
        yes: 'cursor-pointer',
        no: ''
      },
      style: {
        framed: 'gap-4 p-4 lg:gap-4 lg:p-6',
        full: '',
        media_bg: 'overflow-hidden rounded-2xl! bg-(--brand-deep) text-white'
      },
      backgroundColor: {
        default: 'bg-card text-card-foreground hover:bg-card/90 hover:text-card-foreground/90',
        accent: 'bg-accent text-accent-foreground hover:bg-accent/80 hover:text-accent-foreground/80',
        primary: 'bg-primary text-primary-foreground hover:bg-primary/90 hover:text-primary-foreground/90',
        inverted: 'bg-foreground text-background hover:bg-foreground/90 hover:text-background/90',
        noColor: 'shadow-none',
        none: ''
      }
    },
    compound_variants: [
      {
        style: ['framed'],
        backgroundColor: ['noColor'],
        class: 'border border-secondary hover:border-secondary/80'
      },
    ]
  )
%}

{% set card_media =
  html_cva(
    base: 'overflow-hidden',
    variants: {
      orientation: {
        vertical: '',
        horizontal: 'md:aspect-auto md:flex-[0_1_50%]'
      },
      style: {
        framed: 'aspect-video rounded-lg',
        full: 'aspect-video rounded-xl',
        media_bg: 'aspect-[4/5] w-full'
      }
    }
  )
%}

{% set card_content =
  html_cva(
    base: 'flex w-full flex-col items-baseline',
    variants: {
      orientation: {
        vertical: '',
        horizontal: 'md:flex-[0_1_50%]'
      },
      isTextCentered: {
        yes: 'text-center',
        no: ''
      },
      style: {
        framed: '',
        full: 'rounded-b p-4 lg:p-6',
        media_bg: 'absolute inset-x-0 bottom-0 p-6'
      }
    },
    compound_variants: [
      {
        orientation: ['horizontal'],
        style: ['full'],
        class: 'p-4 lg:p-6'
      },
      {
        orientation: ['vertical'],
        backgroundColor: ['noColor'],
        style: ['full'],
        class: 'px-0!'
      },
      {
        orientation: ['horizontal'],
        backgroundColor: ['noColor'],
        style: ['full'],
        class: 'py-0!'
      }
    ]
  )
%}

{# Build the link once; aria-label adds eyebrow context for screen reader link lists. #}
{% set card_link %}
  {% if url is not empty %}
    <a href="{{ url }}" class="after:absolute after:inset-0 after:content-['']"
       {% if eyebrow_text is not empty %}aria-label="{{ eyebrow_text }}: {{ heading_text }}"{% endif %}>{{ heading_text }}</a>
  {% else %}
    {{ heading_text }}
  {% endif %}
{% endset %}

<article
  class="{{
  card.apply(
    {
      orientation: is_media_bg ? 'vertical' : card_orientation,
      clickable: url is not empty ? 'yes' : 'no',
      style: card_style,
      backgroundColor: is_media_bg ? 'none' : card_background
    },
    card_classes|default('')
  )
  }}"
>
  {% if media.src is not empty %}
    <div
      class="{{
      card_media.apply({
        orientation: is_media_bg ? 'vertical' : card_orientation,
        style: card_style
      })
      }}"
    >
      {% block media %}
        {% include 'canvas:image' ignore missing with {
          src: media.src,
          alt: media.alt,
          class: is_media_bg
            ? url is not empty
              ? 'object-cover w-full h-full opacity-85 transition group-hover:scale-[1.03] group-hover:opacity-100'
              : 'object-cover w-full h-full opacity-85'
            : url is not empty
              ? 'object-cover w-full h-full transition group-hover:scale-[1.03]'
              : 'object-cover w-full h-full',
          width: media.width,
          height: media.height,
          sizes: card_orientation == 'horizontal' ? '50vw' : '100vw'
        } only %}
      {% endblock %}
    </div>
  {% endif %}

  {% if is_media_bg %}
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
  {% endif %}

  <div
    class="{{
    card_content.apply({
      orientation: is_media_bg ? 'vertical' : card_orientation,
      isTextCentered: is_text_centered,
      style: card_style,
      backgroundColor: is_media_bg ? 'none' : card_background
    })
    }}"
  >
    <div class="{{ inner_classes }}">
      {% if eyebrow_text is not empty %}
        <p class="mb-0 text-xs font-semibold uppercase tracking-widest text-brand-sun">{{ eyebrow_text }}</p>
      {% endif %}
      <{{ h }} class="{{ heading_classes }}">{{ card_link }}</{{ h }}>
      {% if text is not empty %}
        <p class="{{ text_classes }}">{{ text }}</p>
      {% endif %}
    </div>
  </div>
</article>
