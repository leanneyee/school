{% set button_variant = variant|default('primary') %}
{% set button_size = size|default('medium') %}
{% set is_disabled = disabled|default(false) %}
{% set has_icon = icon is not empty %}

{% set button_variants =
  html_cva(
    base: [
      'group inline-flex items-center justify-center transition duration-300 ease-in-out',
      'font-semibold uppercase tracking-wider',
      'cursor-pointer no-underline outline-none hover:no-underline',
      'focus-visible:ring-ring/50 focus-visible:ring-[3px]',
      'disabled:pointer-events-none disabled:opacity-50'
    ],
    variants: {
      size: {
        small:  'gap-1.5 text-xs',
        medium: 'gap-2 text-sm',
        large:  'gap-2 text-sm'
      },
      variant: {
        primary:
          'bg-primary text-primary-foreground hover:brightness-110',
        secondary:
          'bg-accent text-accent-foreground hover:brightness-105',
        'primary-inverted':
          'text-white hover:text-(--brand-sun)',
        'secondary-inverted':
          'border border-border bg-background text-foreground hover:bg-secondary',
        ghost:
          'text-primary hover:underline',
        link:
          'text-primary hover:underline',
        'link-inverted':
          'text-white hover:text-(--brand-sun)'
      },
      width: {
        full: 'w-full sm:w-fit',
        fit:  'w-fit'
      },
      iconPosition: {
        first: 'flex-row',
        last:  'flex-row-reverse'
      }
    },
    compound_variants: [
      {
        variant: ['primary', 'secondary', 'primary-inverted', 'secondary-inverted', 'ghost'],
        size: ['small'],
        class: 'px-4 py-2 rounded-full leading-tight'
      },
      {
        variant: ['primary', 'secondary', 'primary-inverted', 'secondary-inverted', 'ghost'],
        size: ['medium'],
        class: 'px-6 py-3 rounded-full leading-tight'
      },
      {
        variant: ['primary', 'secondary', 'primary-inverted', 'secondary-inverted', 'ghost'],
        size: ['large'],
        class: 'px-7 py-3.5 rounded-full leading-tight'
      }
    ]
  )
%}

{% set icon_size_map = {
  small:  'extra-extra-small',
  medium: 'extra-small',
  large:  'small'
} %}

{% set button_width    = mobile_width|default(false) ? 'full' : 'fit' %}
{% set icon_position   = icon_first|default(false) ? 'first' : 'last' %}
{% set icon_classes    = 'transition duration-300 ease-in-out group-hover:translate-x-1' %}

{# Normalize btn_classes — handle both array and string formats #}
{% set additional_classes = btn_classes|default('') %}
{% if additional_classes is iterable %}
  {% set additional_classes = additional_classes|join(' ') %}
{% endif %}

{% set disabled_attr        = is_disabled ? 'aria-disabled="true"' : '' %}
{% set button_disabled_attr = is_disabled ? 'disabled' : '' %}
{% set href = disabled|default(false) ? null : href %}

{% set computed_classes = button_variants.apply(
  {
    size:         button_size,
    variant:      button_variant,
    width:        button_width,
    iconPosition: has_icon ? icon_position : 'last'
  },
  additional_classes
) %}

{% if href %}
  <a href="{{ href }}" class="{{ computed_classes }}" {{ disabled_attr }}>
    {% if has_icon %}
      <span class="{{ icon_classes }}">
        {{- include(
          '@kura/components/icon/icon.twig',
          { weight: 'bold', icon: icon, icon_size: icon_size_map[button_size] },
          with_context: false
        ) -}}
      </span>
    {% endif %}
    {{ label }}
  </a>
{% else %}
  <button class="{{ computed_classes }}" {{ button_disabled_attr }}>
    {% if has_icon %}
      <span class="{{ icon_classes }}">
        {{- include(
          '@kura/components/icon/icon.twig',
          { weight: 'bold', icon: icon, icon_size: icon_size_map[button_size] },
          with_context: false
        ) -}}
      </span>
    {% endif %}
    {{ label }}
  </button>
{% endif %}
