{#
/**
 * @file hero.twig
 *
 * Heading strategy
 * ----------------
 * `heading` is ALWAYS an <h1>. Whether it is visible or sr-only is controlled
 * by `heading_hidden`.
 *
 * With heading_hidden true, the tagline props provide the visual heading and
 * the heading text is sr-only. Use this on the homepage where the tagline is
 * the decorative treatment.
 *
 * With heading_hidden false (or omitted), the heading renders visually as the
 * h1. The tagline props are ignored. Use this on interior pages.
 *
 * The tagline props are always aria-hidden — decorative only, never the
 * semantic heading.
 *
 * The quick_links slot accepts one or more kura:quick-link components.
 * Canvas can drop individual quick-link instances into this slot.
 */
#}

{% set is_heading_hidden = heading_hidden|default(false) %}
{% set has_tagline = tagline_line1 is not empty %}

<section class="cq-full relative isolate overflow-hidden bg-(--brand-deep)">

  {% if hero_image.src is not empty %}
    <div class="absolute inset-0 -z-10 h-full w-full">
      {% include 'canvas:image' ignore missing with {
        src: hero_image.src,
        alt: hero_image.alt,
        width: hero_image.width,
        height: hero_image.height,
        loading: 'eager',
        class: 'h-full w-full object-cover object-center opacity-70',
      } only %}
    </div>
  {% endif %}

  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-(--brand-deep)/90 via-(--brand-deep)/60 to-transparent"></div>

  <div class="mx-auto container px-4 pt-24 pb-0 sm:px-6 sm:pt-32 lg:pt-40">
    <div class="grid gap-12 lg:grid-cols-12 lg:items-end">
      <div class="lg:col-span-8">
        {% if eyebrow %}
          <p class="text-xs font-semibold uppercase tracking-[0.25em] text-white/70">
            {{ eyebrow }}
          </p>
        {% endif %}
        {# Semantic h1 — always present, visually hidden when tagline carries the display #}
        <h1 class="{{ is_heading_hidden ? 'sr-only' : 'mt-5 max-w-4xl font-bold leading-[0.95] text-white text-5xl sm:text-7xl lg:text-8xl' }}">
          {{ heading }}
        </h1>
        {# Decorative tagline — visual treatment only, never heard by screen readers #}
        {% if has_tagline and is_heading_hidden %}
          <p class="mt-5 max-w-4xl font-bold leading-[0.95] text-white text-5xl sm:text-7xl lg:text-8xl">
            {{ tagline_line1 }}<br>
            {% if tagline_line2 %}<span class="text-(--brand-sun)">{{ tagline_line2 }}</span><br>{% endif %}
            {% if tagline_line3 %}<span class="text-white">{{ tagline_line3 }}</span>{% endif %}
          </p>
        {% endif %}
        {% if subtitle %}
          <p class="mt-8 max-w-lg text-lg text-white/85">{{ subtitle }}</p>
        {% endif %}
        {% if hero_actions %}
          <div class="mt-10 flex flex-wrap items-center gap-6">
            {{ hero_actions }}
          </div>
        {% endif %}
      </div>

      {% if caption %}
        <aside class="lg:col-span-4 hidden lg:block">
          <figcaption class="border-l-2 border-(--brand-sun) bg-white/5 px-5 py-3 text-xs italic text-white/75 backdrop-blur-sm">
            {{ caption }}
          </figcaption>
        </aside>
      {% endif %}
    </div>

    {% if quick_links %}
      <nav class="hero-quick-links mt-20 grid grid-cols-2 border-t border-white/15 sm:grid-cols-4">
        {{ quick_links }}
      </nav>
    {% endif %}
  </div>
</section>
