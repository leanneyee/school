{% set media_col = html_cva(base: [
  '@container md:col-span-5 md:content-center lg:col-span-3',
]) %}

{% set highlight_classes = html_cva(base: [
  'font-serif text-2xl leading-snug text-foreground sm:text-3xl',
  '[&>p:first-child]:mt-0 [&>p:last-child]:mb-0',
]) %}

{% set body_classes = html_cva(base: [
  'text-base leading-relaxed text-muted-foreground',
  '[&>p:first-child]:mt-0 [&>p:last-child]:mb-0',
]) %}

{% set pos = media_display|default('none') %}
{% set show_media = pos != 'none' %}

{#
  Content is captured once so Canvas-tracked props (heading, attribution)
  appear only once in the compiled template regardless of branch taken.
  DOM order is swapped (not CSS order) to satisfy WCAG 1.3.2.
  media_position drives visibility: "None" = full-width, no media column.
  This is reliable; testing the slot variable directly is not — Canvas always
  injects placeholder markup into empty slots, making emptiness checks
  untrustworthy.
#}
{% set content_col %}
  <div class="flex flex-col justify-center px-4 py-10 sm:px-10 {{ show_media ? 'md:col-span-7 lg:col-span-9' : 'col-span-full' }}">

    {% if heading %}
      <h2 class="text-xs font-semibold uppercase tracking-[0.25em] text-brand-leaf">{{ heading }}</h2>
    {% endif %}

    {% if highlight_text %}
      <p class="mt-6 {{ highlight_classes.apply({}) }}">
        <span class="font-serif text-5xl leading-none text-brand-sun" aria-hidden="true">&ldquo;</span>
        {{ highlight_text|raw }}
      </p>
    {% endif %}

    {% if text %}
      <div class="mt-6 {{ body_classes.apply({}) }}">
        {{ text|raw }}
      </div>
    {% endif %}

    {% if attribution %}
      <p class="mt-6 text-sm font-semibold uppercase tracking-widest text-foreground/80">— {{ attribution }}</p>
    {% endif %}

  </div>
{% endset %}

<div class="mx-auto grid container gap-0 px-0 py-6 sm:px-6 sm:py-8 md:grid-cols-12">

  {% if pos == 'right' %}
    {# Content left, media right — content first in DOM matches visual order #}
    {{ content_col }}
    <div class="{{ media_col.apply({}) }}">{{ media }}</div>
  {% elseif pos == 'left' %}
    {# Media left, content right — media first in DOM matches visual order #}
    <div class="{{ media_col.apply({}) }}">{{ media }}</div>
    {{ content_col }}
  {% else %}
    {# No media: full-width content only #}
    {{ content_col }}
  {% endif %}

</div>
