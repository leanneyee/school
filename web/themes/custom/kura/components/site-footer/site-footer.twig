{% set num_cols = columns|default(4) %}
{% set grid_cols = {2: 'md:grid-cols-2', 3: 'md:grid-cols-3', 4: 'md:grid-cols-4'} %}
{% set grid_col_class = grid_cols[num_cols] ?? 'md:grid-cols-4' %}

{#
  Column wrapper: applies consistent link and layout styles to all columns.
  underline/decoration-white/25: links are distinguishable from surrounding
  text by more than colour alone (WCAG 1.4.1).
#}
{% set col = html_cva(base: [
  'text-white text-sm flex flex-col gap-4',
  '[&_ul]:flex [&_ul]:flex-col [&_ul]:gap-1',
  '[&_a]:text-white/85',
  '[&_a]:underline [&_a]:underline-offset-2 [&_a]:decoration-white/25',
  '[&_a:hover]:text-white [&_a:hover]:decoration-white/60',
  '[&_a:focus-visible]:ring-2 [&_a:focus-visible]:ring-white [&_a:focus-visible]:rounded-sm',
]) %}

<div class="cq-full mt-0 border-t border-border bg-brand-deep text-white/80">
  <div class="mx-auto grid container gap-10 px-4 py-16 sm:px-6 {{ grid_col_class }}">

    <div class="{{ col.apply({}) }}">
      {{ footer_first }}
    </div>

    <div class="{{ col.apply({}) }}">
      {{ footer_second }}
    </div>

    {% if num_cols >= 3 %}
      <div class="{{ col.apply({}) }}">
        {{ footer_third }}
      </div>
    {% endif %}

    {% if num_cols >= 4 %}
      <div class="{{ col.apply({}) }}">
        {{ footer_fourth }}
      </div>
    {% endif %}

  </div>
  <div class="border-t border-white/10 py-5 text-center text-xs text-white/70">
    {% if copyright_name %}&copy; {{ "now"|date("Y") }} {{ copyright_name }}.{% endif %} {{ copyright_suffix }}
  </div>
</div>
