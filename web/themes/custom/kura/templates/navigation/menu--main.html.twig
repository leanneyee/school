{#
/**
 * @file
 * Theme override to display a menu.
 *
 * Available variables:
 * - menu_name: The machine name of the menu.
 * - items: A nested list of menu items. Each menu item contains:
 *   - attributes: HTML attributes for the menu item.
 *   - below: The menu item child items.
 *   - title: The menu link title.
 *   - url: The menu link url, instance of \Drupal\Core\Url
 *   - localized_options: Menu link localized options.
 *   - is_expanded: TRUE if the link has visible children within the current
 *     menu tree.
 *   - is_collapsed: TRUE if the link has children within the current menu tree
 *     that are not currently visible.
 *   - in_active_trail: TRUE if the link is in the active trail.
 */
#}

{% set classes = 'md:flex md:justify-start relative' %}
{% set attributes = attributes ? attributes.addClass(classes) : ' class="' ~ classes ~ '"' %}

<nav {{ attributes }} aria-label="{{ menu_label }}">
  <ul class="flex flex-col gap-1 p-0 md:w-auto md:flex-row" data-level="1">
    {% for item in items %}
      {% set title = item.title is not empty ? item.title : item.text %}
      {# Capture the rendered URL before testing it for emptiness, since it's a Drupal object under the hood.
      The - prefix and suffix prevent errant whitespace in the resulting `url` variable. #}
      {% set url %}
        {{- item.url -}}
      {% endset %}

      {% set item_classes =
        [
          item.in_active_trail ? 'bg-muted/50' : '',
          'group',
          'md:flex md:justify-between',
          'md:w-auto md:relative md:max-w-[375px]',
          'text-sm font-medium rounded-md'
        ]|filter(c => c is not empty)
      %}

      {% if item.attributes %}
        {% do item.attributes.addClass(item_classes) %}
        {% do item.attributes.setAttribute('data-level', 1) %}
      {% else %}
        {% set item_attributes_string = 'class="' ~ (item_classes|join(' ')) ~ '" data-level="1"' %}
      {% endif %}

      <li {{ item.attributes ? : item_attributes_string }}>
        {% if url is not empty %}
          <a
            href="{{ url }}"
            class="flex min-h-[44px] shrink-1 grow-1 basis-0 items-center gap-1 rounded-md p-2 duration-300 md:min-h-auto hover:md:bg-primary hover:md:text-primary-foreground focus:md:bg-primary focus:md:text-primary-foreground xl:px-3"
            data-level="1"
          >
            {{ title }}
          </a>
        {% endif %}

        {% if item.below %}
          {# Mobile: always-visible indented list. Desktop: hover dropdown.
             pt-3 provides a hover bridge so the cursor can travel from
             the trigger to the panel without the menu dismissing. #}
          <ul class="
            list-none p-0
            ml-3 border-l border-border pl-3
            md:ml-0 md:pl-0 md:border-0
            md:absolute md:left-0 md:top-full md:z-50
            md:pt-3 md:transition
            md:invisible md:opacity-0
            md:group-hover:visible md:group-hover:opacity-100
          ">

            {# Desktop dropdown panel #}
            <li class="max-md:hidden md:block">
              <div class="min-w-56 border-t-2 border-primary bg-popover py-2 shadow-(--shadow-soft)">
                <ul class="list-none p-0">
                  {% for child in item.below %}
                    {% set child_url %}{{- child.url -}}{% endset %}
                    <li>
                      <a
                        href="{{ child_url }}"
                        class="block px-4 py-2 text-sm text-popover-foreground hover:bg-muted hover:text-foreground{{ child.in_active_trail ? ' text-primary' : '' }}"
                      >
                        {{ child.title }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            </li>

            {# Mobile sub-items — flat list, always visible in mobile overlay #}
            {% for child in item.below %}
              {% set child_url %}{{- child.url -}}{% endset %}
              <li class="md:hidden">
                <a
                  href="{{ child_url }}"
                  class="block rounded-md px-3 py-1.5 text-sm text-muted-foreground hover:text-foreground{{ child.in_active_trail ? ' text-primary' : '' }}"
                >
                  {{ child.title }}
                </a>
              </li>
            {% endfor %}

          </ul>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</nav>
