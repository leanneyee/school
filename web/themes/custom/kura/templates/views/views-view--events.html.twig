{#
  Upcoming Events block — homepage section.
  Two-column layout: heading + CTA on the left, events list on the right.
  The block is hidden automatically when the view returns no results
  (block_hide_empty is set on the block display).
#}
{% if header %}
  <div class="view-header">
    {{ header }}
  </div>
{% endif %}
{% if rows %}
  <ul class="list-none p-0">
    {{ rows }}
  </ul>
{% elseif empty %}
  <div class="rounded-lg border border-dashed border-border bg-secondary/30 px-6 py-10 text-center font-semibold text-foreground">
    {{ empty }}
  </div>
{% endif %}
{% if pager %}
  {{ pager }}
{% endif %}
